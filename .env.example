# Closer local environment template.
# Copy to .env.local and fill real values. Do not commit .env.local.

CLOSER_ALLOW_DEV_AUTH=1
CLOSER_CREDENTIALS_SECRET=replace-with-a-local-secret

# MiniMax China OpenAI-compatible endpoint.
OPENAI_API_KEY=replace-with-minimax-api-key
OPENAI_BASE_URL=https://api.minimaxi.com/v1
CLOSER_AGENT_MODEL=openai-chat:MiniMax-M3
CLOSER_GRAPH_DECISION_PROVIDER=openai
CLOSER_GRAPH_DECISION_MODEL=MiniMax-M3
CLOSER_GRAPH_DECISION_BASE_URL=https://api.minimaxi.com/v1
CLOSER_GRAPH_DECISION_TIMEOUT_SECONDS=60

# Keep payload_only until you explicitly want real outbound email/WhatsApp sending.
CLOSER_DELIVERY_MODE=payload_only
